@if (Visible)
{
    <div class="modal is-active config-modal-shell" @onclick="OnCloseRequested">
        <div class="modal-background modal-backdrop"></div>
        <div class="modal-card config-modal-card glass-panel" @onclick:stopPropagation="true">
            <header class="config-modal-header">
                <div>
                    <span class="panel-kicker">系统配置</span>
                    <h2>文档源管理</h2>
                    <p>本地目录与 Git 仓库二选一保存，配置会写入服务器根目录的 <code>data/config.json</code>。</p>
                </div>
                <button class="icon-button" type="button" @onclick="OnCloseRequested" aria-label="关闭配置">×</button>
            </header>

            <section class="config-modal-body">
                @if (Model.Sources.Count == 0)
                {
                    <div class="empty-state compact-empty">
                        <h3>还没有文档源</h3>
                        <p>先添加一个源，主界面的目录切换和文件浏览就会启用。</p>
                    </div>
                }

                @foreach (var source in Model.Sources)
                {
                    <section class="source-card" @key="source.Id">
                        <div class="source-card-header">
                            <div>
                                <span class="source-badge">文档源</span>
                                <h3>@(string.IsNullOrWhiteSpace(source.Name) ? "未命名文档源" : source.Name)</h3>
                            </div>
                            <button class="ghost-button danger" type="button" @onclick="() => RemoveSource(source.Id)">删除</button>
                        </div>

                        <div class="field-grid two-columns">
                            <label class="field-block">
                                <span>源名称</span>
                                <input class="input shell-input" @bind="source.Name" placeholder="例如：团队知识库" />
                            </label>

                            <label class="field-block">
                                <span>数据来源方式</span>
                                <div class="segmented-control">
                                    <button class="@GetKindButtonClass(source, DocumentSourceKind.Local)" type="button" @onclick="() => SetKind(source, DocumentSourceKind.Local)">服务器本地路径</button>
                                    <button class="@GetKindButtonClass(source, DocumentSourceKind.Git)" type="button" @onclick="() => SetKind(source, DocumentSourceKind.Git)">Git 仓库拉取</button>
                                </div>
                            </label>
                        </div>

                        @if (source.Kind == DocumentSourceKind.Local)
                        {
                            <label class="field-block">
                                <span>服务器绝对路径</span>
                                <input class="input shell-input" @bind="source.LocalPath" placeholder="例如：C:\Docs\Wiki 或 /home/docs/wiki" />
                            </label>
                        }
                        else
                        {
                            <div class="field-grid two-columns">
                                <label class="field-block">
                                    <span>仓库地址</span>
                                    <input class="input shell-input" @bind="source.GitRepositoryUrl" placeholder="https://github.com/example/repo.git" />
                                </label>

                                <label class="field-block">
                                    <span>拉取间隔（分钟）</span>
                                    <input class="input shell-input" type="number" min="1" step="1" @bind="source.PullIntervalMinutes" />
                                </label>
                            </div>

                            <label class="field-block">
                                <span>子目录路径</span>
                                <input class="input shell-input" @bind="source.SubDirectory" placeholder="docs/api，留空表示整个仓库" />
                            </label>

                            <label class="field-block">
                                <span>认证方式</span>
                                <div class="segmented-control">
                                    <button class="@GetAuthButtonClass(source, GitAuthMode.None)" type="button" @onclick="() => SetGitAuthMode(source, GitAuthMode.None)">无需认证</button>
                                    <button class="@GetAuthButtonClass(source, GitAuthMode.UsernamePassword)" type="button" @onclick="() => SetGitAuthMode(source, GitAuthMode.UsernamePassword)">用户名密码</button>
                                    <button class="@GetAuthButtonClass(source, GitAuthMode.Token)" type="button" @onclick="() => SetGitAuthMode(source, GitAuthMode.Token)">访问令牌</button>
                                </div>
                            </label>

                            @if (source.GitAuthMode == GitAuthMode.UsernamePassword)
                            {
                                <div class="field-grid two-columns">
                                    <label class="field-block">
                                        <span>用户名</span>
                                        <input class="input shell-input" @bind="source.GitUserName" placeholder="git-user" />
                                    </label>
                                    <label class="field-block">
                                        <span>密码</span>
                                        <input class="input shell-input" type="password" @bind="source.GitPassword" placeholder="请输入密码" />
                                    </label>
                                </div>
                            }
                            else if (source.GitAuthMode == GitAuthMode.Token)
                            {
                                <label class="field-block">
                                    <span>访问令牌</span>
                                    <input class="input shell-input" type="password" @bind="source.GitToken" placeholder="PAT / Access Token" />
                                </label>
                            }
                        }
                    </section>
                }

                <button class="accent-button wide-button" type="button" @onclick="AddSource">新增文档源</button>
            </section>

            <footer class="config-modal-footer">
                <button class="ghost-button" type="button" @onclick="OnCloseRequested">取消</button>
                <button class="accent-button" type="button" disabled="@IsSaving" @onclick="SaveAsync">@(IsSaving ? "保存中..." : "保存配置")</button>
            </footer>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public AppConfigDto Model { get; set; } = new();

    [Parameter]
    public bool IsSaving { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<AppConfigDto> OnSave { get; set; }

    private void AddSource()
    {
        Model.Sources.Add(new DocumentSourceDto
        {
            Id = Guid.NewGuid().ToString("N"),
            Name = $"文档源 {Model.Sources.Count + 1}",
            PullIntervalMinutes = 30
        });
    }

    private void RemoveSource(string sourceId)
    {
        var item = Model.Sources.FirstOrDefault(source => source.Id == sourceId);
        if (item is not null)
        {
            Model.Sources.Remove(item);
        }
    }

    private void SetKind(DocumentSourceDto source, DocumentSourceKind kind)
    {
        source.Kind = kind;
        if (kind == DocumentSourceKind.Local)
        {
            source.GitRepositoryUrl = null;
            source.SubDirectory = null;
            source.GitAuthMode = GitAuthMode.None;
            source.GitUserName = null;
            source.GitPassword = null;
            source.GitToken = null;
        }
        else
        {
            source.LocalPath = null;
            if (source.PullIntervalMinutes <= 0)
            {
                source.PullIntervalMinutes = 30;
            }
        }
    }

    private void SetGitAuthMode(DocumentSourceDto source, GitAuthMode authMode)
    {
        source.GitAuthMode = authMode;
        if (authMode == GitAuthMode.None)
        {
            source.GitUserName = null;
            source.GitPassword = null;
            source.GitToken = null;
        }
        else if (authMode == GitAuthMode.UsernamePassword)
        {
            source.GitToken = null;
        }
        else
        {
            source.GitUserName = null;
            source.GitPassword = null;
        }
    }

    private string GetKindButtonClass(DocumentSourceDto source, DocumentSourceKind kind) =>
        source.Kind == kind ? "segment-button active" : "segment-button";

    private string GetAuthButtonClass(DocumentSourceDto source, GitAuthMode authMode) =>
        source.GitAuthMode == authMode ? "segment-button active" : "segment-button";

    private Task OnCloseRequested() => OnClose.InvokeAsync();

    private Task SaveAsync() => OnSave.InvokeAsync(Model);
}
