@page "/"
@implements IAsyncDisposable
@inject ApiClient ApiClient
@inject ClientAuthService AuthService
@inject MarkdownRendererService MarkdownRenderer
@inject IJSRuntime JS

<PageTitle>MD Viewer</PageTitle>

<div class="is-flex is-flex-direction-column has-background-white-ter" style="height: 100vh; overflow: hidden;">
    <nav class="navbar is-white mb-0 py-2" role="navigation" aria-label="main navigation"
         style="z-index: 10; border-bottom: 1px solid rgba(0,0,0,0.04); background: linear-gradient(90deg, #ffffff 0%, #fdfbfb 100%);">
        <div class="navbar-brand">
            <div class="navbar-item px-5 is-flex is-align-items-center">
                <div class="is-flex is-align-items-center is-justify-content-center has-background-primary has-text-white mr-3" style="width: 36px; height: 36px; border-radius: 10px; box-shadow: 0 4px 10px rgba(0, 209, 178, 0.3);">
                    <i class="fas fa-book-open"></i>
                </div>
                <span class="has-text-weight-bold is-size-4 has-text-dark" style="letter-spacing: -0.5px;">MD Viewer</span>
                <span class="tag is-primary is-light ml-3 is-rounded has-text-weight-medium">在线文档查看器</span>
            </div>
        </div>

        <div class="navbar-menu is-active">
            <div class="navbar-end pr-5">
                <div class="navbar-item">
                    <div class="buttons">
                        @if (CurrentSource is not null && CurrentSource.Kind == DocumentSourceKind.Git)
                        {
                            <button class="button is-info is-light is-small is-rounded has-text-weight-medium" type="button" disabled="@_isSyncing"
                                    @onclick="SyncCurrentSourceAsync" style="transition: all 0.3s; border: none; box-shadow: 0 2px 6px rgba(50, 152, 220, 0.15);">
                                @(_isSyncing ? "同步中..." : "立即同步")
                            </button>
                        }
                        <button class="button is-primary is-small is-rounded has-text-weight-medium" type="button" @onclick="OpenConfigModal"
                                aria-label="系统配置" style="transition: all 0.3s; padding: 0 16px; box-shadow: 0 4px 10px rgba(0, 209, 178, 0.2);">
                            <span class="icon is-small"><i class="fas fa-cog"></i></span>
                            <span>系统配置</span>
                        </button>
                        <div class="is-flex is-align-items-center ml-2 pl-3" style="border-left: 1px solid #eee;">
                            <span class="tag is-dark is-light is-medium is-rounded has-text-weight-semibold">@AuthService.CurrentUserName</span>
                            <button class="button is-danger is-light is-small is-rounded ml-2" type="button"
                                    @onclick="LogoutAsync" style="border: none;">退出</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    @if (!string.IsNullOrWhiteSpace(_noticeMessage))
    {
        <div class="notification @(_noticeIsError ? "is-danger" : "is-info") is-light is-radiusless mb-0 py-2 px-4 is-size-7 shadow-sm">
            <button class="delete" @onclick='() => ShowNotice("", false)'></button>
            @_noticeMessage
        </div>
    }

    <div class="columns is-gapless is-flex-grow-1 mx-4 mt-4 mb-4" style="height: calc(100vh - 80px); gap: 1.5rem;">
        <aside class="column is-3 p-0 is-flex is-flex-direction-column my-0"
               style="max-width: 320px; box-shadow: 0 10px 25px rgba(0,0,0,0.03); border-radius: 16px; border: 1px solid rgba(0,0,0,0.04); background: #ffffff;">
            <div class="p-4"
                 style="border-bottom: 1px solid rgba(0,0,0,0.04); background-color: #fafbfc; border-top-left-radius: 16px; border-top-right-radius: 16px;">
                <div class="field">
                    <label class="label is-small has-text-grey has-text-weight-bold" style="letter-spacing: 0.5px;">文档源</label>
                    <div class="control">
                        <div class="select is-fullwidth is-small is-primary">
                            <select value="@SelectedSourceId" @onchange="OnSourceChangedAsync" style="border-radius: 8px; box-shadow: 0 2px 4px rgba(0,209,178,0.1); border-color: rgba(0,209,178,0.3);">
                                <option value="">请选择文档源</option>
                                @foreach (var source in _config.Sources)
                                {
                                    <option value="@source.Id">@source.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="field mt-4">
                    <div class="control has-icons-left">
                        <input class="input is-small is-rounded" value="@_searchText" @oninput="OnSearchChangedAsync"
                               placeholder="搜索文档或内容..." style="box-shadow: inset 0 1px 3px rgba(0,0,0,0.02); background-color: #f4f6f8; border: none;" />
                        <span class="icon is-small is-left has-text-grey">
                            <i class="fas fa-search"></i>
                        </span>
                    </div>
                </div>

                <nav class="breadcrumb is-small mt-4 mb-0 has-bullet-separator has-text-weight-medium" aria-label="breadcrumbs">
                    <ul class="is-marginless">
                        @if (_currentDirectory is null)
                        {
                            <li class="is-active"><a href="javascript:void(0)" aria-current="page"
                                                         class="has-text-grey">根目录</a></li>
                            }
                        else
                            {
                                @foreach (var crumb in _currentDirectory.Breadcrumbs)
                                {
                                    <li>
                                        <a href="javascript:void(0)" class="has-text-info has-text-weight-medium"
                                           @onclick="() => NavigateToDirectoryAsync(crumb.RelativePath)">@crumb.Name</a>
                                    </li>
                                }
                            }
                        </ul>
                    </nav>
                </div>

                <div class="p-0 menu is-flex-grow-1"
                     style="overflow-y: auto; background-color: #ffffff; border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;">
                    <div class="px-5 py-3 is-flex is-justify-content-space-between is-align-items-center"
                         style="position: sticky; top: 0; z-index: 5; background-color: rgba(255,255,255,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0,0,0,0.03);">
                        <p class="menu-label mb-0 has-text-weight-bold has-text-primary" style="letter-spacing: 0.5px;">
                            @(_isSearchMode ? "搜索结果" : "文件列表")
                        </p>
                            @if (_isLoadingEntries)
                            {
                                <span class="tag is-primary is-light is-rounded is-small">
                                    <i class="fas fa-circle-notch fa-spin mr-1"></i> 加载中
                                </span>
                            }
                        </div>

                        <div class="px-3 pb-4 pt-2">
                            @if (!_config.Sources.Any())
                            {
                                <div class="notification is-warning is-light is-small mt-3 mx-2" style="border-radius: 12px;">
                                    <strong>还没有配置文档源</strong><br />
                                    请通过右上角添加来源。
                                </div>
                            }
                            else if (_visibleEntries.Count == 0)
                            {
                                <div class="notification is-info is-light is-small mt-3 mx-2" style="border-radius: 12px; background-color: #f0f4f8; color: #4a5568;">
                                    <strong>没有找到结果</strong><br />
                                    @(_isSearchMode ? "试试更短的关键词。" : "当前目录是空的。")
                                </div>
                            }
                            else
                            {
                                <ul class="menu-list">
                                    <Virtualize Items="_visibleEntries" Context="entry" ItemSize="48">
                                        <li>
                                            <a class="@GetEntryClass(entry) is-flex is-align-items-center py-2 px-3 my-1"
                                                   style="border-radius: 8px; transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);"
                                                   @onclick="() => OpenEntryAsync(entry)">
                                                <span
                                                    class="tag @(entry.IsDirectory ? "is-warning is-light" : "is-primary is-light") mr-3 is-rounded has-text-weight-bold"
                                                    style="width: 36px; height: 36px; font-size: 0.65rem; border: none; flex-shrink: 0;">
                                                    @(entry.IsDirectory ? "📁" : "📄")
                                                </span>
                                                <div class="is-flex-grow-1 is-clipped" style="line-height: 1.4;">
                                                    <div class="is-size-6 has-text-weight-semibold is-ellipsis"
                                                         style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #2d3748;"
                                                         title="@entry.Name">
                                                        @((MarkupString)HighlightText(entry.Name))
                                                    </div>
                                                    @if (_isSearchMode && !string.IsNullOrWhiteSpace(entry.DisplayPath))
                                                    {
                                                        <div class="has-text-grey"
                                                             style="font-size: 0.65rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
                                                             title="@entry.DisplayPath">
                                                            @entry.DisplayPath
                                                        </div>
                                                    }
                                                </div>
                                                <div
                                                    class="has-text-right ml-2 is-flex is-flex-direction-column is-align-items-flex-end">
                                                    @if (entry.IsContentMatch)
                                                    {
                                                        <span class="tag is-danger is-light is-rounded mb-1"
                                                              style="font-size: 0.6rem; padding: 0 4px; height: auto;">匹配</span>
                                                    }
                                                    @if (!entry.IsDirectory)
                                                    {
                                                        <span class="has-text-grey-light"
                                                              style="font-size: 0.6rem;">@FormatBytes(entry.Size)</span>
                                                    }
                                                </div>
                                            </a>
                                        </li>
                                    </Virtualize>
                                </ul>
                            }
                        </div>
                    </div>
                </aside>

                <section class="column p-0 is-flex is-flex-direction-column my-0"
                         style="position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border-radius: 16px; border: 1px solid rgba(0,0,0,0.04); background: #ffffff; overflow: hidden;">
                    @if (_currentDocument is null)
                    {
                        <div class="is-flex is-justify-content-center is-align-items-center" style="height: 100%; background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%);">
                            <div class="has-text-centered">
                                <div class="mb-5 is-inline-block" style="background: white; border-radius: 50%; padding: 2.5rem; box-shadow: 0 15px 35px rgba(0,0,0,0.05), inset 0 0 0 1px rgba(0,0,0,0.05);">
                                    <span class="has-text-primary" style="font-size: 4rem; line-height: 1;"><i class="fas fa-layer-group"></i></span>
                                </div>
                                <h2 class="title is-4 has-text-dark has-text-weight-bold" style="letter-spacing: -0.5px;">欢迎来到 MD Viewer</h2>
                                <p class="is-size-6 has-text-grey mt-3" style="max-width: 320px; line-height: 1.6;">请从左侧选择文档开始阅读。系统原生支持 Markdown 解析、代码高亮和目录快速导航。</p>
                                <div class="mt-5">
                                    <span class="tag is-primary is-light is-rounded is-medium mx-1" style="font-weight: 500;">Markdown渲染</span>
                                    <span class="tag is-info is-light is-rounded is-medium mx-1" style="font-weight: 500;">代码高亮</span>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="px-6 py-4 is-flex is-justify-content-space-between is-align-items-center"
                             style="border-bottom: 1px solid rgba(0,0,0,0.04); background-color: #ffffff; flex-shrink: 0;">
                            <div>
                                <div class="is-flex is-align-items-center mb-2">
                                    <span class="tag is-primary is-light is-rounded has-text-weight-bold"
                                          style="font-size: 0.65rem; padding: 0 12px; letter-spacing: 0.5px;">@_currentDocument.SourceName</span>
                                </div>
                                <h2 class="title is-3 mb-0 has-text-dark" style="font-weight: 800; letter-spacing: -0.5px; color: #1a202c;">@_currentDocument.Name</h2>
                            </div>
                            <div
                                class="text-right has-text-grey is-size-7 is-flex is-flex-direction-column is-align-items-flex-end is-hidden-mobile">
                                <span class="mb-2 tag is-white shadow-sm is-rounded" style="border: 1px solid #f0f0f0;">大小: @FormatBytes(_currentDocument.Size)</span>
                                <span class="tag is-white shadow-sm is-rounded has-text-grey-light" style="border: 1px solid #f0f0f0;">
                                    <i class="far fa-clock mr-1"></i> @_currentDocument.ModifiedAt.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                                </div>
                            </div>

                            <div class="is-flex is-flex-grow-1"
                                 style="overflow: hidden; background-color: #fafbfc;">
                                <div class="p-6 is-flex-grow-1" style="overflow-y: auto; background-color: #ffffff;" @ref="_scrollElement">
                                    <article class="content markdown-body" style="max-width: 860px; margin: 0 auto;"
                                             @ref="_markdownElement">
                                        @_renderedMarkdown
                                    </article>
                                </div>

                                @if (_headings.Count > 0)
                                {
                                    <div class="is-flex is-flex-direction-column"
                                         style="width: 280px; border-left: 1px solid rgba(0,0,0,0.04); background: #fdfdfd; flex-shrink: 0; box-shadow: -4px 0 15px rgba(0,0,0,0.01);">
                                        <div class="px-5 py-4 is-flex is-align-items-center"
                                             style="border-bottom: 1px solid rgba(0,0,0,0.04); background: #ffffff;">
                                            <span class="has-text-weight-bold is-size-6 has-text-primary" style="letter-spacing: 0.5px;">目录导航</span>
                                        </div>
                            
                                        <div class="p-4 menu" style="overflow-y: auto; flex: 1;">
                                            <ul class="menu-list is-size-7" style="line-height: 1.6;">
                                                @foreach (var heading in _headings)
                                                {
                                                    <li>
                                                        <a class="@GetHeadingClass(heading) py-2 mb-1"
                                                               style="padding-left: @(0.5 + (heading.Level - 1) * 0.8)rem; border-radius: 8px; transition: all 0.25s;"
                                                               @onclick="() => ScrollToHeadingAsync(heading.Id)">
                                                            @heading.Text
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </section>
                </div>
            </div>

<ConfigModal Visible="@_showConfigModal" Model="@_editingConfig" IsSaving="@_isSavingConfig" OnClose="CloseConfigModal"
             OnSave="SaveConfigAsync" />

@code {
    private static readonly JsonSerializerOptions CloneOptions = new(JsonSerializerDefaults.Web)
    {
        Converters =
        {
            new System.Text.Json.Serialization.JsonStringEnumConverter()
        }
    };

    private readonly AppConfigDto _config = new();
    private AppConfigDto _editingConfig = new();
    private readonly List<HeadingItem> _headings = [];
    private readonly List<DirectoryEntryDto> _visibleEntries = [];
    private ElementReference _markdownElement;
    private ElementReference _scrollElement;
    private DotNetObjectReference<ViewerPage>? _dotNetReference;
    private CancellationTokenSource? _searchCancellationSource;
    private DirectoryBrowseResponse? _currentDirectory;
    private MarkdownDocumentDto? _currentDocument;
    private MarkupString _renderedMarkdown;
    private DocumentSourceDto? CurrentSource { get; set; }
    private string SelectedSourceId => CurrentSource?.Id ?? string.Empty;
    private string _searchText = string.Empty;
    private string _activeHeadingId = string.Empty;
    private string _noticeMessage = string.Empty;
    private bool _noticeIsError;
    private bool _isSearchMode;
    private bool _isLoadingEntries;
    private bool _isSavingConfig;
    private bool _isSyncing;
    private bool _showConfigModal;
    private bool _pendingMarkdownRefresh;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetReference = DotNetObjectReference.Create(this);
        }

        if (_pendingMarkdownRefresh && _currentDocument is not null && _dotNetReference is not null)
        {
            _pendingMarkdownRefresh = false;
            var headings = await JS.InvokeAsync<List<HeadingItem>>("mdViewerUi.refreshMarkdownView", _markdownElement,
_scrollElement, _dotNetReference);
            _headings.Clear();
            _headings.AddRange(headings.Where(item => item.Level >= 2));
            StateHasChanged();
        }
    }

    [JSInvokable]
    public Task SetActiveHeading(string headingId)
    {
        _activeHeadingId = headingId;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task LoadConfigAsync()
    {
        await RunGuardedAsync(async () =>
        {
            var config = await ApiClient.GetConfigAsync();
            _config.Sources.Clear();
            _config.Sources.AddRange(config.Sources);

            if (CurrentSource is null || _config.Sources.All(source => source.Id != CurrentSource.Id))
            {
                CurrentSource = _config.Sources.FirstOrDefault();
            }
            else
            {
                CurrentSource = _config.Sources.First(source => source.Id == CurrentSource.Id);
            }

            if (CurrentSource is not null)
            {
                await LoadDirectoryAsync(CurrentSource.Id, _currentDirectory?.CurrentPath);
            }
            else
            {
                _currentDirectory = null;
                _visibleEntries.Clear();
                _currentDocument = null;
                _renderedMarkdown = default;
            }
        }, "加载配置失败");
    }

    private async Task OnSourceChangedAsync(ChangeEventArgs args)
    {
        var sourceId = args.Value?.ToString();
        CurrentSource = _config.Sources.FirstOrDefault(source => source.Id == sourceId);
        _searchText = string.Empty;
        _isSearchMode = false;
        _currentDocument = null;
        _headings.Clear();
        _visibleEntries.Clear();
        _renderedMarkdown = default;

        if (CurrentSource is not null)
        {
            await LoadDirectoryAsync(CurrentSource.Id, string.Empty);
        }
    }

    private async Task LoadDirectoryAsync(string sourceId, string? path)
    {
        _isLoadingEntries = true;
        StateHasChanged();

        await RunGuardedAsync(async () =>
        {
            _currentDirectory = await ApiClient.BrowseAsync(sourceId, path);
            _visibleEntries.Clear();
            _visibleEntries.AddRange(_currentDirectory.Entries);
            _isSearchMode = false;
        }, "读取目录失败");

        _isLoadingEntries = false;
        StateHasChanged();
    }

    private async Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _searchCancellationSource?.Cancel();
        _searchCancellationSource?.Dispose();
        _searchCancellationSource = new CancellationTokenSource();
        var cancellationToken = _searchCancellationSource.Token;

        if (CurrentSource is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_searchText))
        {
            await LoadDirectoryAsync(CurrentSource.Id, _currentDirectory?.CurrentPath);
            return;
        }

        _isLoadingEntries = true;
        StateHasChanged();

        try
        {
            await Task.Delay(220, cancellationToken);
            var results = await ApiClient.SearchAsync(CurrentSource.Id, _searchText, cancellationToken);
            _visibleEntries.Clear();
            _visibleEntries.AddRange(results);
            _isSearchMode = true;
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (UnauthorizedAccessException)
        {
            await AuthService.LogoutAndRedirectAsync();
            return;
        }
        catch (Exception exception)
        {
            ShowNotice($"搜索失败：{exception.Message}", true);
        }
        finally
        {
            _isLoadingEntries = false;
            StateHasChanged();
        }
    }

    private async Task OpenEntryAsync(DirectoryEntryDto entry)
    {
        if (CurrentSource is null)
        {
            return;
        }

        if (entry.IsDirectory)
        {
            await LoadDirectoryAsync(CurrentSource.Id, entry.RelativePath);
            return;
        }

        await OpenDocumentAsync(CurrentSource.Id, entry.RelativePath);
    }

    private async Task OpenDocumentAsync(string sourceId, string relativePath)
    {
        await RunGuardedAsync(async () =>
        {
            _currentDocument = await ApiClient.GetDocumentAsync(sourceId, relativePath);
            _renderedMarkdown = MarkdownRenderer.Render(_currentDocument.Content);
            _pendingMarkdownRefresh = true;

            var parentPath = GetParentPath(relativePath);
            if (CurrentSource is not null && (!_isSearchMode || _currentDirectory?.CurrentPath != parentPath))
            {
                _currentDirectory = await ApiClient.BrowseAsync(sourceId, parentPath);
            }

            _visibleEntries.Clear();
            if (_isSearchMode)
            {
                var results = await ApiClient.SearchAsync(sourceId, _searchText);
                _visibleEntries.AddRange(results);
            }
            else if (_currentDirectory is not null)
            {
                _visibleEntries.AddRange(_currentDirectory.Entries);
            }
        }, "打开文档失败");
    }

    private async Task NavigateToDirectoryAsync(string relativePath)
    {
        if (CurrentSource is not null)
        {
            _searchText = string.Empty;
            await LoadDirectoryAsync(CurrentSource.Id, relativePath);
        }
    }

    private void OpenConfigModal()
    {
        _editingConfig = CloneConfig(_config);
        _showConfigModal = true;
    }

    private Task CloseConfigModal()
    {
        _showConfigModal = false;
        return Task.CompletedTask;
    }

    private async Task SaveConfigAsync(AppConfigDto config)
    {
        _isSavingConfig = true;
        StateHasChanged();

        await RunGuardedAsync(async () =>
        {
            var savedConfig = await ApiClient.SaveConfigAsync(config);
            _config.Sources.Clear();
            _config.Sources.AddRange(savedConfig.Sources);
            CurrentSource = _config.Sources.FirstOrDefault(source => source.Id == CurrentSource?.Id) ??
_config.Sources.FirstOrDefault();
            _showConfigModal = false;

            if (CurrentSource is not null)
            {
                await LoadDirectoryAsync(CurrentSource.Id, string.Empty);
            }
            else
            {
                _currentDirectory = null;
                _currentDocument = null;
                _visibleEntries.Clear();
            }

            ShowNotice("配置已保存。", false);
        }, "保存配置失败");

        _isSavingConfig = false;
        StateHasChanged();
    }

    private async Task SyncCurrentSourceAsync()
    {
        if (CurrentSource is null)
        {
            return;
        }

        _isSyncing = true;
        StateHasChanged();

        await RunGuardedAsync(async () =>
        {
            var result = await ApiClient.SyncAsync(CurrentSource.Id);
            await LoadDirectoryAsync(CurrentSource.Id, _currentDirectory?.CurrentPath);
            ShowNotice(result.Message, !result.Success);
        }, "手动同步失败");

        _isSyncing = false;
        StateHasChanged();
    }

    private async Task LogoutAsync() =>
        await AuthService.LogoutAndRedirectAsync();

    private async Task ScrollToHeadingAsync(string headingId)
    {
        await JS.InvokeVoidAsync("mdViewerUi.scrollToHeading", _scrollElement, headingId);
    }

    private async Task RunGuardedAsync(Func<Task> action, string title)
    {
        try
        {
            await action();
        }
        catch (UnauthorizedAccessException)
        {
            await AuthService.LogoutAndRedirectAsync();
        }
        catch (Exception exception)
        {
            ShowNotice($"{title}：{exception.Message}", true);
        }
    }

    private void ShowNotice(string message, bool isError)
    {
        _noticeMessage = message;
        _noticeIsError = isError;
    }

    private static AppConfigDto CloneConfig(AppConfigDto config)
    {
        var json = JsonSerializer.Serialize(config, CloneOptions);
        return JsonSerializer.Deserialize<AppConfigDto>(json, CloneOptions) ?? new AppConfigDto();
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var value = bytes / 1024d;
        if (value < 1024)
        {
            return $"{value:F1} KB";
        }

        return $"{value / 1024d:F1} MB";
    }

    private string HighlightText(string text)
    {
        var encoded = System.Net.WebUtility.HtmlEncode(text);
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return encoded;
        }

        return System.Text.RegularExpressions.Regex.Replace(
            encoded,
            System.Text.RegularExpressions.Regex.Escape(_searchText),
            match => $"<mark>{match.Value}</mark>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
    }

    private string GetEntryClass(DirectoryEntryDto entry)
    {
        var selected = _currentDocument?.RelativePath == entry.RelativePath;
        return selected ? "is-active has-background-white box shadow-sm has-text-info-dark has-text-weight-bold" :
"has-text-grey-dark";
    }

    private string GetHeadingClass(HeadingItem heading)
    {
        var active = string.Equals(_activeHeadingId, heading.Id, StringComparison.Ordinal);
        return active ? "is-active has-background-white box shadow-sm has-text-info-dark has-text-weight-bold" :
"has-text-grey-dark";
    }

    private string GetActiveHeadingTitle()
    {
        var currentHeading = _headings.FirstOrDefault(item => item.Id == _activeHeadingId);
        return currentHeading?.Text ?? "浏览文档结构";
    }

    private static string GetParentPath(string relativePath)
    {
        if (string.IsNullOrWhiteSpace(relativePath) || !relativePath.Contains('/'))
        {
            return string.Empty;
        }

        return relativePath[..relativePath.LastIndexOf('/')];
    }

    public async ValueTask DisposeAsync()
    {
        _searchCancellationSource?.Cancel();
        _searchCancellationSource?.Dispose();

        if (_dotNetReference is not null)
        {
            await JS.InvokeVoidAsync("mdViewerUi.disposeMarkdownView", _scrollElement);
            _dotNetReference.Dispose();
        }
    }
}
